{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"types": ["vite/client", "node", "vitest/globals"]
	},
	"include": ["src/**/*", "tests/**/*"]
}
