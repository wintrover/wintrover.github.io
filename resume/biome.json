{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"root": false,
	"files": {
		"includes": [
			"src/**/*.{js,ts,jsx,tsx,json}",
			"*.{js,json}",
			"vite.config.js",
			"svelte.config.js",
			"vitest.setup.js",
			".dependency-cruiser.json",
			"!!**/node_modules",
			"!!**/build",
			"!!**/dist",
			"!!**/.svelte-kit",
			"!!static"
		]
	},
	"vcs": {
		"enabled": false
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
