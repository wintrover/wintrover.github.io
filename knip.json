{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/main.ts",
		"src/App.svelte",
		"src/components/**/*.svelte",
		"scripts/*.ts",
		"tests/*.ts"
	],
	"project": ["src/**/*.{ts,svelte}", "scripts/**/*.ts", "tests/**/*.ts"],
	"ignore": [],
	"ignoreDependencies": ["@biomejs/biome", "@vitest/coverage-v8", "mermaid"],
	"ignoreBinaries": ["code-index-mcp"]
}
